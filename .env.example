# Required
SERVER_PRIVATE_KEY=       # WIF private key for node identity
HOSTING_URL=              # Public HTTPS URL (e.g., https://stas3.metawatt.io/)
MONGO_URL=                # MongoDB connection string (e.g., mongodb://localhost:27017/stas3)

# Optional
SERVER_PORT=8080          # HTTP port (default: 8080)
SQL_DB=./data.db          # SQLite path or MySQL/Postgres connection string
ADMIN_TOKEN=              # Admin API bearer token (auto-generated if not set)
ARC_API_KEY=              # ARC transaction processor API key
